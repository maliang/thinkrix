{
    "name": "lartrix/thinkrix",
    "version": "1.0.5",
    "description": "ThinkPHP 8 后台管理包，为 trix 前端提供 API 接口",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "maliang",
            "email": "maliang47@foxmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "topthink/framework": "^8.0",
        "topthink/think-migration": "^3.1",
        "topthink/think-orm": "^3.0|^4.0",
        "phpoffice/phpspreadsheet": "^2.0|^3.0",
        "wikimedia/composer-merge-plugin": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "giorgiosironi/eris": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "Thinkrix\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Thinkrix\\Tests\\": "tests/"
        }
    },
    "extra": {
        "think": {
            "services": [
                "Thinkrix\\ThinkrixService"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
